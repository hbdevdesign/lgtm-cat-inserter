{
  "manifest_version": 3,
  "name": "LGTM Cat Inserter",
  "version": "1.3",
  "description": "GitHubのコメント欄に猫のLGTM画像を挿入します",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://github.com/*",
    "https://lgtmeow.com/*",
    "https://*.lgtmeow.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icons/cat.png"
  },
  "action": {
    "default_icon": {
      "48": "icons/cat.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/cat.png"],
      "matches": ["https://github.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}